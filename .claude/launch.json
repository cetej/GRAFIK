{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "grafik-api",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "grafik.api.app:app", "--port", "8200", "--host", "127.0.0.1"],
      "port": 8200,
      "autoPort": false
    },
    {
      "name": "grafik-ui",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "streamlit", "run", "ui/app.py", "--server.port", "8501", "--server.headless", "true"],
      "port": 8501
    }
  ]
}
